    "Dense Passage Retriever (DPR)": {
      "aliases": [],
      "status": "unreviewed",
      "definition": "A dual-encoder dense retrieval model that embeds questions and passages into a shared vector space and retrieves relevant passages by maximizing inner products.",
      "source": "defines",
      "first_seen": "2004.04906"
    },
    "Longformer": {
      "aliases": [],
      "status": "unreviewed",
      "definition": "A modified Transformer architecture with a sparse attention mechanism that scales linearly with sequence length for processing long documents.",
      "source": "defines",
      "first_seen": "2004.05150"
    },
    "LED": {
      "aliases": [],
      "status": "unreviewed",
      "definition": "A Longformer-based encoder-decoder model designed for long-document sequence-to-sequence tasks such as summarization.",
      "source": "defines",
      "first_seen": "2004.05150"
    },
    "Switch Transformer": {
      "aliases": [],
      "status": "unreviewed",
      "definition": "A simplified mixture-of-experts transformer that routes each input token to a single expert to enable sparse, scalable training with reduced communication and computation costs.",
      "source": "defines",
      "first_seen": "2101.03961"
    },
    "FLAN": {
      "aliases": [],
      "status": "unreviewed",
      "definition": "A pretrained language model instruction-tuned on many NLP datasets phrased as natural language instructions to improve zero-shot performance on unseen tasks.",
      "source": "defines",
      "first_seen": "2109.01652"
    },
    "Chinchilla": {
      "aliases": [],
      "status": "unreviewed",
      "definition": "A compute-optimal 70B-parameter language model trained with substantially more data to maximize performance under a fixed compute budget.",
      "source": "defines",
      "first_seen": "2203.15556"
    },
    "PaLM": {
      "aliases": [],
      "status": "unreviewed",
      "definition": "A 540-billion-parameter densely activated Transformer language model trained to study the effects of scaling on few-shot learning and broad language capabilities.",
      "source": "defines",
      "first_seen": "2204.02311"
    },
    "FlashAttention": {
      "aliases": [],
      "status": "unreviewed",
      "definition": "An IO-aware exact attention algorithm that uses tiling and kernel fusion to minimize GPU memory traffic between HBM and SRAM.",
      "source": "defines",
      "first_seen": "2205.14135"
    },
    "block-sparse FlashAttention": {
      "aliases": [],
      "status": "unreviewed",
      "definition": "A sparse attention variant built on FlashAttention that exploits block sparsity to further reduce memory access and speed up attention.",
      "source": "defines",
      "first_seen": "2205.14135"
    },
    "emergent abilities of large language models": {
      "aliases": [],
      "status": "unreviewed",
      "definition": "Abilities that are absent in smaller-scale models but present in larger-scale models, and therefore cannot be predicted by extrapolating smaller-model performance.",
      "source": "defines",
      "first_seen": "2206.07682"
    },
    "SELF-INSTRUCT": {
      "aliases": [],
      "status": "unreviewed",
      "definition": "A semi-automated bootstrapping framework that improves instruction-following by generating synthetic instructions and instances from a language model and using them to finetune the same model.",
      "source": "defines",
      "first_seen": "2212.10560"
    },
    "REPLUG LSR": {
      "aliases": [],
      "status": "unreviewed",
      "definition": "A training scheme that uses a black-box language model’s scores to supervise and improve the retriever.",
      "source": "defines",
      "first_seen": "2301.12652"
    },
    "Generative Agents": {
      "aliases": [],
      "status": "unreviewed",
      "definition": "Computational agents that simulate believable human behavior by storing, reflecting on, and retrieving memories to plan and act over time.",
      "source": "defines",
      "first_seen": "2304.03442"
    },
    "RankGPT": {
      "aliases": [],
      "status": "unreviewed",
      "definition": "A prompting and distillation framework that uses large language models to rank passages by directly generating permutations of candidate passages.",
      "source": "defines",
      "first_seen": "2304.09542"
    },
    "Plan-and-Solve (PS) Prompting": {
      "aliases": [],
      "status": "unreviewed",
      "definition": "A zero-shot prompting strategy that first asks the model to devise a plan to break a problem into subtasks and then solve the subtasks according to that plan.",
      "source": "defines",
      "first_seen": "2305.04091"
    },
    "PS+ Prompting": {
      "aliases": [],
      "status": "unreviewed",
      "definition": "An extended Plan-and-Solve prompting strategy that adds more detailed instructions to improve reasoning quality and reduce calculation errors.",
      "source": "defines",
      "first_seen": "2305.04091"
    },
    "Guanaco": {
      "aliases": [],
      "status": "unreviewed",
      "definition": "A family of chatbot models finetuned with QLORA that achieves strong Vicuna benchmark performance.",
      "source": "defines",
      "first_seen": "2305.14314"
    },
    "VOYAGER": {
      "aliases": [],
      "status": "unreviewed",
